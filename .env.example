# myscrape-go configuration. Copy to .env (gitignored) or export these.
# Every engine is inert until its key is set; setting one auto-joins the round-robin.

# --- Search providers (DDG + Marginalia work with no key) ---
MYSCRAPE_TAVILY_API_KEY=
MYSCRAPE_EXA_API_KEY=
MYSCRAPE_SERPAPI_API_KEY=
MYSCRAPE_SERPER_API_KEY=
MYSCRAPE_MOJEEK_API_KEY=
# Google Programmable Search needs BOTH:
MYSCRAPE_GOOGLE_API_KEY=
MYSCRAPE_GOOGLE_CSE_ID=

# --- Synthesis (web_research) ---
# "simple" = extractive, GPU-free (default). "llm" = model-written answer.
MYSCRAPE_RESEARCH_SYNTHESIS=simple
# Only used when synthesis=llm (OpenAI-compatible endpoint; Ollama/llama.cpp/etc.):
MYSCRAPE_LLM_BASE_URL=http://localhost:11434/v1
MYSCRAPE_LLM_MODEL=qwen2.5:14b
MYSCRAPE_LLM_API_KEY=

# --- Transport ---
MYSCRAPE_MCP_TRANSPORT=stdio          # stdio | http
MYSCRAPE_MCP_HOST=127.0.0.1
MYSCRAPE_MCP_PORT=8000
